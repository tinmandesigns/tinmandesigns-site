          width: 28px;
          height: 28px;
        }
        .mobile-toggle {
          display: block !important;
        }
      }

      /* --- MACHINED MOBILE NAV --- */
      .mobile-toggle {
        display: none;
        background: var(--metal-light);
        border: 1px solid var(--metal-trim);
        border-radius: 4px;
        width: 44px;
        height: 44px;
        position: relative;
        cursor: pointer;
        box-shadow:
          inset 0 1px 2px #fff,
          0 2px 5px rgba(0, 0, 0, 0.1);
        z-index: 1100;
        padding: 0;
        box-sizing: border-box;
        outline: none;
      }
      .mobile-toggle:active {
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);
        transform: translateY(1px);
      }
      .toggle-bolt {
        position: absolute;
        width: 6px;
        height: 6px;
        background: var(--metal-trim);
        border: 1px solid var(--metal-dark);
        border-radius: 50%;
        box-shadow:
          inset -1px -1px 1px rgba(0, 0, 0, 0.3),
          inset 1px 1px 1px #fff;
        transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }
      .toggle-bolt::after {
        content: "";
        position: absolute;
        top: 40%;
        left: 10%;
        right: 10%;
        height: 1px;
        background: rgba(0, 0, 0, 0.4);
        transform: rotate(45deg);
      }
      .toggle-bolt.tl {
        top: 4px;
        left: 4px;
      }
      .toggle-bolt.tr {
        top: 4px;
        right: 4px;
      }
      .toggle-bolt.bl {
        bottom: 4px;
        left: 4px;
      }
      .toggle-bolt.br {
        bottom: 4px;
        right: 4px;
      }

      /* Spin bolts on open */
      .menu-open .mobile-toggle .toggle-bolt {
        transform: rotate(180deg);
      }

      /* Hamburger Lines */
      .mobile-toggle .line {
        display: block;
        width: 20px;
        height: 2px;
        background: var(--metal-forged);
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 2px;
        transition: all 0.4s ease;
      }
      .mobile-toggle .line-1 {
        top: 14px;
      }
      .mobile-toggle .line-2 {
        top: 21px;
      }
      .mobile-toggle .line-3 {
        top: 28px;
      }

      /* Transform to X */
      .menu-open .mobile-toggle .line-1 {
        top: 21px;
        transform: translateX(-50%) rotate(45deg);
      }
      .menu-open .mobile-toggle .line-2 {
        opacity: 0;
      }
      .menu-open .mobile-toggle .line-3 {
        top: 21px;
        transform: translateX(-50%) rotate(-45deg);
      }

      /* Mobile Nav Panel */
      .mobile-nav-panel {
        position: fixed;
        top: 0;
        right: -100%;
        width: 80%;
        max-width: 350px;
        height: 100vh;
        background: var(--bg-panel);
        border-left: 2px solid var(--metal-dark);
        box-shadow: -10px 0 30px rgba(0, 0, 0, 0.8);
        z-index: 1050;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 3rem 2rem;
        box-sizing: border-box;
        transition: right 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .menu-open .mobile-nav-panel {
        right: 0;
      }

      .mobile-nav-panel .panel-grid-lines {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
        background-size: 20px 20px;
        pointer-events: none;
        z-index: 0;
      }

      .mobile-nav-links {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .mobile-nav-links a.mob-link {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--metal-forged);
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--metal-trim);
        opacity: 0;
        transform: translateX(30px);
        transition:
          opacity 0.4s ease,
          transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
          color 0.3s;
      }

      .mobile-nav-links a.mob-link:hover {
        color: var(--metal-dark);
      }

      .menu-open .mobile-nav-links a.mob-link {
        opacity: 1;
        transform: translateX(0);
      }

      /* Staggered entrance for links */
      .menu-open .mobile-nav-links a.mob-link:nth-child(1) {
        transition-delay: 0.3s;
      }
      .menu-open .mobile-nav-links a.mob-link:nth-child(2) {
        transition-delay: 0.4s;
      }
      .menu-open .mobile-nav-links a.mob-link:nth-child(3) {
        transition-delay: 0.5s;
      }
      .menu-open .mobile-nav-links a.mob-link:nth-child(4) {
        transition-delay: 0.6s;
      }
      .menu-open .mobile-nav-links a.mob-link:nth-child(5) {
        transition-delay: 0.7s;
      }
      .menu-open .mobile-nav-links a.mob-link:nth-child(6) {
        transition-delay: 0.8s;
      }
      .menu-open .mobile-nav-links a.mob-link:nth-child(7) {
        transition-delay: 0.9s;
      }

      .menu-open .mobile-nav-links .btn {
        opacity: 0;
        transform: translateX(30px);
        animation: mobBtnFade 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards 1.0s;
      }
      @keyframes mobBtnFade {
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }

      /* Dark Overlay */
      .mobile-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(6px);
        z-index: 1040;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.5s ease;
      }
      .menu-open .mobile-overlay {
        opacity: 1;
        pointer-events: auto;
      }

      /* --- FAQ ACCORDION --- */
      .faq-section {
        padding: 6rem 5%;
        max-width: 900px;
        margin: 0 auto;
      }
      .faq-header {
        text-align: center;
        margin-bottom: 3.5rem;
      }
      .faq-header h2 {
        font-size: 2.8rem;
        margin-bottom: 1rem;
      }
      .faq-header p {
        color: var(--text-muted);
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto;
      }
      .faq-item {
        background: var(--metal-light);
        border: 1px solid var(--metal-trim);
        border-radius: 4px;
        margin-bottom: 1rem;
        box-shadow:
          inset 0 1px 0 #ffffff,
          0 2px 5px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        transition: all 0.3s ease;
        position: relative;
      }
      .faq-item.active {
        border-color: #10b981;
        box-shadow:
          0 5px 15px rgba(16, 185, 129, 0.1),
          inset 0 1px 0 rgba(255, 255, 255, 0.5);
      }
      .faq-question {
        padding: 1.5rem 2rem;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--metal-forged);
        user-select: none;
        position: relative;
        background: var(--brushed-bg);
      }
      .faq-question::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        width: 4px;
        background: transparent;
        transition: background 0.3s;
      }
      .faq-item.active .faq-question::before {
        background: #10b981;
      }
      .faq-icon {
        width: 24px;
        height: 24px;
        position: relative;
        flex-shrink: 0;
        background: var(--bg-panel);
        border-radius: 50%;
        border: 1px solid var(--metal-trim);
        box-shadow:
          inset 1px 1px 2px #fff,
          inset -1px -1px 2px rgba(0, 0, 0, 0.1);
      }
      .faq-icon::before,
      .faq-icon::after {
        content: "";
        position: absolute;
        background: var(--metal-dark);
        transition:
          transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
          background 0.3s;
        border-radius: 1px;
      }
      .faq-icon::before {
        top: 10px;
        left: 5px;
        right: 5px;
        height: 2px;
      }
      .faq-icon::after {
        top: 5px;
        bottom: 5px;
        left: 10px;
        width: 2px;
      }
      .faq-item.active .faq-icon::before,
      .faq-item.active .faq-icon::after {
        background: #10b981;
      }
      .faq-item.active .faq-icon::after {
        transform: rotate(90deg);
      }
      .faq-answer-wrapper {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .faq-item.active .faq-answer-wrapper {
        grid-template-rows: 1fr;
      }
      .faq-answer {
        overflow: hidden;
      }
      .faq-answer-inner {
        padding: 0 2rem 1.5rem;
        color: var(--text-muted);
        line-height: 1.6;
        border-top: 1px dashed transparent;
        transition:
          border-color 0.4s,
          padding-top 0.4s;
      }
      .faq-item.active .faq-answer-inner {
        padding-top: 1.5rem;
        border-color: rgba(
          255,
          255,
          255,
          0.1
        ); /* Optional, adds a subtle separator */
      }
      .sheen-link {
        color: #10b981;
        font-weight: 800;
        text-decoration: none;
        padding-bottom: 2px;
        border-bottom: 2px solid rgba(16, 185, 129, 0.4);
        position: relative;
        overflow: hidden;
        display: inline-flex;
        align-items: baseline;
        white-space: nowrap;
        transition: all 0.3s ease;
      }
      .sheen-link:hover {
        border-color: #10b981;
        color: #059669;
      }
      .sheen-link::after {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 30%;
        height: 100%;
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.6) 50%,
          rgba(255, 255, 255, 0) 100%
        );
        transform: skewX(-20deg);
        animation: sheenEffect 6s infinite;
      }
      @keyframes sheenEffect {
        0% {
          left: -100%;
        }
        25% {
          left: 200%;
        }
        100% {
          left: 200%;
        }
      }
    </style>
